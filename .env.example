# .env.example — Plantilla de variables de entorno
# ─────────────────────────────────────────────────────────────────────────────
# Copia este archivo como .env y completa los valores reales.
# Este archivo SÍ se sube al repositorio (sin valores sensibles).
#
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── SQL Server LOCAL (Docker) ───────────────────────────────────────────────
SA_PASSWORD=TuContraseniaSegura123!
MSSQL_PID=Developer
DB_NAME=PortalCV

# Usuario de aplicación local (runtime): privilegios mínimos sobre PortalCV
APP_DB_USER=portalcv_app
APP_DB_PASSWORD=TuPasswordAppSegura123!

# ── Backend ──────────────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development

# Conexión LOCAL (Docker): usa portalcv_app
ConnectionStrings__DefaultConnection=Server=db,1433;Database=PortalCV;User Id=portalcv_app;Password=TuPasswordAppSegura123!;TrustServerCertificate=True;

# Conexión AZURE SQL (producción): usa portalcv_app_prod
# ConnectionStrings__DefaultConnection=Server=sql-<tu-servidor>.database.windows.net,1433;Database=PortalCV;User Id=portalcv_app_prod;Password=TuPasswordProd!;Encrypt=True;TrustServerCertificate=False;

# JWT base
Jwt__Issuer=PortalCV.Api
Jwt__Audience=PortalCV.Client
Jwt__Key=ReemplazarPorClaveSeguraJWT_MinimO32Caracteres!

# CORS: orígenes del navegador permitidos (obligatorio en producción si Cors:AllowedOrigins está vacío en appsettings).
# Local Angular: http://localhost:4200  |  Producción: https://<tu-dominio-static-web-app>.azurestaticapps.net
# Cors__AllowedOrigins__0=http://localhost:4200
# Cors__AllowedOrigins__1=https://tu-app.azurestaticapps.net

# Usuario demo para endpoint /api/auth/login (solo dev)
Auth__DemoUser__Email=admin@portalcv.local
Auth__DemoUser__Password=CambiarPasswordDemo

# ── Azure SQL (solo para referencia — NO subir valores reales) ───────────────
# AZURE_SQL_SERVER=sql-<tu-servidor>.database.windows.net
# AZURE_SQL_DB=PortalCV
# AZURE_SQL_USER=portalcv_app_prod
# AZURE_SQL_PASSWORD=<contraseña-segura>

# ── Puertos expuestos ────────────────────────────────────────────────────────
PORT_DB=1433
PORT_BACKEND=5000
PORT_FRONTEND=4200
