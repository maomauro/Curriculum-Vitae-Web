# .env.example — Plantilla de variables de entorno
# ─────────────────────────────────────────────────────────────────────────────
# Copia este archivo como .env y completa los valores reales.
# Este archivo SÍ se sube al repositorio (sin valores sensibles).
#
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── SQL Server ───────────────────────────────────────────────────────────────
SA_PASSWORD=TuContraseniaSegura123!
MSSQL_PID=Developer
DB_NAME=PortalCV

# Usuario de aplicación (runtime): privilegios mínimos sobre PortalCV
APP_DB_USER=portalcv_app
APP_DB_PASSWORD=TuPasswordAppSegura123!

# ── Backend ──────────────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development

# Conexión que usa ASP.NET Core (sobrescribe appsettings con env vars)
ConnectionStrings__DefaultConnection=Server=db,1433;Database=PortalCV;User Id=portalcv_app;Password=TuPasswordAppSegura123!;TrustServerCertificate=True;

# JWT base
Jwt__Issuer=PortalCV.Api
Jwt__Audience=PortalCV.Client
Jwt__Key=ReemplazarPorClaveSeguraJWT

# Usuario demo para endpoint /api/auth/login (solo dev)
Auth__DemoUser__Email=admin@portalcv.local
Auth__DemoUser__Password=CambiarPasswordDemo

# ── Puertos expuestos ────────────────────────────────────────────────────────
PORT_DB=1433
PORT_BACKEND=5000
PORT_FRONTEND=4200
