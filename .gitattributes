# .gitattributes
# Garantiza que los scripts de shell siempre usen LF (Linux)
# aunque el repositorio se clone en Windows.
# Crítico para scripts que corren dentro de contenedores Linux.

# Por defecto: normalizar a LF en el repo
* text=auto

# Shell scripts: siempre LF (corren en Linux/Docker)
*.sh text eol=lf

# Archivos de configuración Docker: LF
Dockerfile text eol=lf
docker-compose*.yml text eol=lf
nginx.conf text eol=lf

# Windows: CRLF para estos archivos
*.bat text eol=crlf
*.ps1 text eol=crlf
