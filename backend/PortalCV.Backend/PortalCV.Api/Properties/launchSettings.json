{
  "$schema": "https://json.schemastore.org/launchsettings.json",
  "//": "Este archivo NO debe contener secretos (Jwt__Key, passwords). Los secretos se cargan con 'dotnet user-secrets' (flujo nativo) o con docker/backend.local.env (flujo Docker). Ver backend/README.md seccion 'Secretos locales'.",
  "profiles": {
    "http": {
      "commandName": "Project",
      "dotnetRunMessages": true,
      "launchBrowser": false,
      "applicationUrl": "http://localhost:5005",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ConnectionStrings__DefaultConnection": "Server=.\\SQLEXPRESS;Database=PortalCV;Trusted_Connection=true;Encrypt=false;TrustServerCertificate=true;"
      }
    },
    "https": {
      "commandName": "Project",
      "dotnetRunMessages": true,
      "launchBrowser": false,
      "applicationUrl": "https://localhost:7070;http://localhost:5005",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ConnectionStrings__DefaultConnection": "Server=.\\SQLEXPRESS;Database=PortalCV;Trusted_Connection=true;Encrypt=false;TrustServerCertificate=true;"
      }
    }
  }
}
