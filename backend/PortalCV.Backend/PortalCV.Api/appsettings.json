{
  "Cors": {
    "AllowedOrigins": []
  },
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Jwt": {
    "Issuer": "PortalCV.Api",
    "Audience": "PortalCV.Client",
    "Key": ""
  },
  "Auth": {
    "DemoUser": {
      "Email": "",
      "Password": ""
    }
  },
  "PublicSnapshot": {
    "RefreshIntervalMinutes": 10,
    "BootstrapRetrySeconds": 15,
    "Blob": {
      "ConnectionString": "",
      "ContainerName": "portalcv-snapshots",
      "BlobName": "public-cvs-snapshot.json"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
