# Plantilla para ejecutar el backend en contenedor (Docker Desktop) contra SQL Server en tu Windows.
# Copia este archivo a `docker/backend.local.env` (NO versionado) y completa valores reales.
#
#   PowerShell: Copy-Item docker/backend.local.env.example docker/backend.local.env
#
# Luego:
#   docker build -f backend/Dockerfile -t portalcv-backend:local ./backend
#   docker run --rm -p 5005:8080 --add-host=host.docker.internal:host-gateway --env-file docker/backend.local.env --name portalcv-api-local portalcv-backend:local

ASPNETCORE_ENVIRONMENT=Development

# Expone la API en el puerto interno esperado por el Dockerfile (8080).
ASPNETCORE_URLS=http://+:8080

# Desde el contenedor Linux, `host.docker.internal` apunta al host Windows.
# Ajusta puerto/instancia/usuario segun tu SQL local (SQLEXPRESS a veces usa puerto dinamico: habilita TCP o usa el puerto correcto).
#
# Si ves errores tipo "Network is unreachable" a una IPv6, fuerza preferencia IPv4 en SqlClient:
#   IPAddressPreference=IPv4First
ConnectionStrings__DefaultConnection=Server=host.docker.internal,1433;Database=PortalCV;User Id=REEMPLAZAR_USUARIO_SQL;Password=REEMPLAZAR_PASSWORD_SQL;Encrypt=True;TrustServerCertificate=True;IPAddressPreference=IPv4First;

Jwt__Issuer=PortalCV.Api
Jwt__Audience=PortalCV.Client
Jwt__Key=REEMPLAZAR_CLAVE_JWT_MINIMO_32_CARACTERES

# Opcional: usuario demo si lo usas en desarrollo
# Auth__DemoUser__Email=demo@local.test
# Auth__DemoUser__Password=REEMPLAZAR_PASSWORD_DEMO
